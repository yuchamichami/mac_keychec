{
  "$schema": "https://design-tokens.org/schema.json",
  "color": {
    "bg": {
      "window":      { "value": "#0B1030", "swiftui": "Color(red: 0.043, green: 0.063, blue: 0.188)" },
      "windowGrad":  { "value": "#171347", "swiftui": "Color(red: 0.090, green: 0.075, blue: 0.278)" },
      "card":        { "value": "#0E0F24", "swiftui": "Color(red: 0.055, green: 0.059, blue: 0.141)" },
      "cardHover":   { "value": "#131428", "swiftui": "Color(red: 0.075, green: 0.078, blue: 0.157)" }
    },
    "accent": {
      "cyan":     { "value": "#5BD1FF" },
      "cyan2":    { "value": "#2E8BFF" }
    },
    "event": {
      "down":  { "value": "#5BFF8B" },
      "up":    { "value": "#FFA85B" },
      "peak":  { "value": "#FF5F5F" }
    },
    "text": {
      "primary":   { "value": "#ECEEFF" },
      "secondary": { "value": "#7D8090" }
    },
    "metal": {
      "knobLight": { "value": "#3A3D4A" },
      "knobDark":  { "value": "#1D1F28" }
    },
    "keycap": {
      "topLight":  { "value": "#FCFCFE" },
      "topDark":   { "value": "#D2D2DE" },
      "sideLight": { "value": "#A6A6B8" },
      "sideDark":  { "value": "#5A5A70" }
    },
    "divider": { "value": "rgba(255,255,255,0.04)" }
  },
  "radius": {
    "window":  { "value": 12 },
    "card":    { "value": 10 },
    "keycap":  { "value":  6 },
    "tile":    { "value": 14 },
    "chip":    { "value":  6 }
  },
  "spacing": {
    "windowPadding":   { "value": 28 },
    "barGap":          { "value": 28 },
    "rowHeight":       { "value": 56 },
    "keycapWidthTone": { "value": 88 },
    "keycapWidthAct":  { "value": 76 },
    "keycapHeight":    { "value": 48 }
  },
  "size": {
    "knobDiameter":  { "value": 84 },
    "knobInset":     { "value": 12 },
    "knobIndicator": { "width": 2, "height": 14 },
    "powerButton":   { "value": 56 },
    "powerLed":      { "value": 6 },
    "rowAccentBar":  { "width": 4, "height": 56 }
  },
  "knob": {
    "arcStartDeg": { "value": -135 },
    "arcEndDeg":   { "value":  135 },
    "peakAtPct":   { "value": 100 },
    "maxPct":      { "value": 150 },
    "arcStrokeWidth": { "value": 3 }
  },
  "shadow": {
    "rowAccentGlow": {
      "blur":  { "value": 8 },
      "spread":{ "value": 0 },
      "alpha": { "value": 1.0 }
    },
    "knobInner": {
      "topHighlight":   { "value": "inset 0 1px 0 rgba(255,255,255,0.15)" },
      "bottomShadow":   { "value": "inset 0 -3px 6px rgba(0,0,0,0.7)" },
      "outerDrop":      { "value": "0 4px 10px rgba(0,0,0,0.5)" }
    }
  },
  "typography": {
    "mono":     { "family": "JetBrains Mono", "axes": ["wght 400..700"] },
    "rowDir":   { "size": 22, "weight": 300 },
    "rowCode":  { "size": 14, "weight": 500 },
    "rowMeta":  { "size": 11, "weight": 400 },
    "rowUsage": { "size": 11, "weight": 400 },
    "label":    { "size": 11, "weight": 500, "tracking": 2,  "transform": "uppercase" },
    "section":  { "size": 10, "weight": 500, "tracking": 3,  "transform": "uppercase" },
    "valueChip":{ "size": 11, "weight": 500, "feature": "tnum" }
  },
  "animation": {
    "knobRotate": { "duration": 100, "easing": "easeOut" },
    "buttonPress":{ "duration":  80, "scale": 0.96 },
    "newRowFlash":{ "duration": 200, "easing": "easeOut" },
    "scanline":   { "duration": 6000, "easing": "linear", "loop": true }
  }
}
